---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-border-divider py-12 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <img src={`${import.meta.env.BASE_URL}logo.svg`} alt="Handled" class="w-6 h-6" />
      <span class="font-heading font-semibold text-white">handled.sh</span>
    </div>
    <p class="text-text-muted text-sm">
      &copy; {year} Handled. Free forever. Pro when you're ready.
    </p>
  </div>
</footer>
