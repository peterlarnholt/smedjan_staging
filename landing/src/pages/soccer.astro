---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Handled for World Cup 2026 — Organize watch sessions from WhatsApp"
  description="Plan World Cup watch parties, track match schedules, and coordinate with friends — all from WhatsApp or Telegram."
  canonical="https://handled.sh/soccer/"
  icpSegment="soccer"
  geoTarget="global"
>
  <Nav cta="Get Started — Free" ctaLink="https://handled.sh" />
  <main class="pt-20">

    <!-- Hero -->
    <section class="min-h-[80vh] flex items-center px-6 py-20">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="font-mono text-brand-light text-sm mb-4 tracking-wider uppercase">World Cup 2026</p>
          <h1 class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl text-white tracking-tight leading-tight mb-6">
            Your World Cup.<br /><span class="text-brand-light">Handled.</span>
          </h1>
          <p class="text-text-secondary text-lg md:text-xl mb-8 leading-relaxed">
            Match reminders, watch party coordination, score alerts — all from the group chat you're already in. No extra app needed.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://handled.sh" class="px-8 py-4 bg-brand-purple text-white font-heading font-bold text-lg rounded-xl shadow-glow-lg hover:bg-brand-dark transition-all text-center">
              Add to Your Group Chat — Free
            </a>
          </div>
          <p class="text-text-muted text-sm mt-4">Works in WhatsApp & Telegram. Free forever.</p>
        </div>
        <div class="bg-surface-card border border-border-default rounded-2xl p-6 shadow-glow">
          <div class="space-y-4">
            <div class="flex justify-end">
              <div class="bg-brand-dark/30 border border-brand-purple/20 rounded-2xl rounded-br-md px-4 py-3 max-w-xs">
                <p class="font-mono text-sm text-text-primary">Set up match reminders for all Argentina games. Alert the group 30 min before kickoff.</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-surface-subtle border border-border-default rounded-2xl rounded-bl-md px-4 py-3 max-w-sm">
                <p class="font-mono text-sm text-brand-light">Done. I'll send reminders to this group 30 minutes before every Argentina match. Next: Argentina vs Mexico, June 15 at 8pm ET.</p>
              </div>
            </div>
            <div class="flex justify-end">
              <div class="bg-brand-dark/30 border border-brand-purple/20 rounded-2xl rounded-br-md px-4 py-3 max-w-xs">
                <p class="font-mono text-sm text-text-primary">Where should we watch? Find a sports bar near downtown that takes reservations.</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-surface-subtle border border-border-default rounded-2xl rounded-bl-md px-4 py-3 max-w-sm">
                <p class="font-mono text-sm text-brand-light">Found 3 options. Want me to make a reservation for 8 people at Champions Bar at 7:30pm?</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Use cases -->
    <section class="px-6 py-20 border-t border-border-divider">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-4">
          Everything your crew needs
        </h2>
        <p class="text-text-secondary text-center mb-16 max-w-xl mx-auto">
          One assistant in your group chat. Everyone benefits.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">⚽</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Match reminders</h3>
            <p class="text-text-secondary">"Remind us 30 minutes before every group stage match." Never miss kickoff again.</p>
          </div>
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">📍</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Watch party planning</h3>
            <p class="text-text-secondary">"Find a place for 10 people for Saturday's match." Venue research, done in seconds.</p>
          </div>
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">📅</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Schedule coordination</h3>
            <p class="text-text-secondary">"Add the semifinal to everyone's calendar." One message, whole group synced.</p>
          </div>
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">🍕</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Food & drink runs</h3>
            <p class="text-text-secondary">"Remind me to order pizza at 7pm before the game." The important stuff, handled.</p>
          </div>
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">🏆</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Bracket tracking</h3>
            <p class="text-text-secondary">"What's the knockout bracket look like?" Instant answers without googling.</p>
          </div>
          <div class="bg-surface-card border border-border-default rounded-xl p-8">
            <div class="text-3xl mb-4">🌐</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Time zone help</h3>
            <p class="text-text-secondary">"What time is the final in London?" Perfect for friends across time zones.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="px-6 py-20 border-t border-border-divider">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-16">
          Add Handled to your group in 30 seconds
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <div class="w-16 h-16 rounded-2xl bg-brand-purple/10 border border-brand-purple/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-brand-light text-2xl">1</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Sign up free</h3>
            <p class="text-text-secondary">Create your account at handled.sh. Takes 10 seconds.</p>
          </div>
          <div>
            <div class="w-16 h-16 rounded-2xl bg-brand-purple/10 border border-brand-purple/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-brand-light text-2xl">2</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Add to group chat</h3>
            <p class="text-text-secondary">Invite Handled to your WhatsApp or Telegram group.</p>
          </div>
          <div>
            <div class="w-16 h-16 rounded-2xl bg-brand-purple/10 border border-brand-purple/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-brand-light text-2xl">3</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Just ask</h3>
            <p class="text-text-secondary">Message Handled in the group. Everyone sees the answers and reminders.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-20 border-t border-border-divider">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-4">
          The World Cup starts soon.<br />Your group chat is ready.
        </h2>
        <p class="text-text-secondary mb-8">Free forever. Works in 7 languages.</p>
        <a href="https://handled.sh" class="inline-block px-10 py-5 bg-brand-purple text-white font-heading font-bold text-xl rounded-xl shadow-glow-lg hover:bg-brand-dark transition-all">
          Get Handled — Free
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Base>
