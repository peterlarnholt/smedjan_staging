---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="World Cup 2026 — Live scores, reminders & news in WhatsApp | Handled"
  description="104 matches. 3 time zones. Get live scores, match reminders, player stats, and news — all in WhatsApp. No app to download."
  canonical="https://handled.sh/worldcup/"
  icpSegment="soccer"
  geoTarget="global"
>
  <Nav cta="Get it on WhatsApp" ctaLink="https://handled.sh/whatsapp" />
  <main class="pt-20 bg-[#0a1a0a]">

    <!-- Hero -->
    <section class="min-h-[85vh] flex items-center px-6 py-16 relative overflow-hidden">
      <!-- Subtle pitch lines -->
      <div class="absolute inset-0 opacity-5">
        <div class="absolute top-1/2 left-0 right-0 h-px bg-[#23DF8C]"></div>
        <div class="absolute top-1/2 left-1/2 w-32 h-32 border border-[#23DF8C] rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      </div>

      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <div class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-[#23DF8C]/10 text-[#23DF8C] border border-[#23DF8C]/20 font-mono tracking-wider uppercase">
            FIFA World Cup 2026
          </div>
          <h1 class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl text-white tracking-tight leading-tight mb-3">
            104 MATCHES.<br />3 TIME ZONES.
          </h1>
          <h2 class="font-heading font-extrabold text-3xl md:text-4xl lg:text-5xl text-[#23DF8C] tracking-tight leading-tight mb-6">
            YOUR WORLD CUP. HANDLED.
          </h2>
          <p class="text-[#a0a0a0] text-lg md:text-xl mb-8 leading-relaxed">
            FotMob for scores. FIFA for schedule. Twitter for news. Google for stats.
            <span class="text-white font-semibold">Or... one WhatsApp message.</span>
          </p>

          <!-- Countdown -->
          <div class="flex gap-4 mb-8" id="countdown">
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-xl px-4 py-3 text-center min-w-[70px]">
              <div class="text-[#23DF8C] font-heading font-bold text-2xl" id="days">--</div>
              <div class="text-[#707070] text-xs uppercase tracking-wider">Days</div>
            </div>
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-xl px-4 py-3 text-center min-w-[70px]">
              <div class="text-[#23DF8C] font-heading font-bold text-2xl" id="hours">--</div>
              <div class="text-[#707070] text-xs uppercase tracking-wider">Hours</div>
            </div>
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-xl px-4 py-3 text-center min-w-[70px]">
              <div class="text-[#23DF8C] font-heading font-bold text-2xl" id="mins">--</div>
              <div class="text-[#707070] text-xs uppercase tracking-wider">Min</div>
            </div>
          </div>

          <a href="https://handled.sh/whatsapp" class="inline-flex items-center gap-3 px-8 py-4 bg-[#23DF8C] text-[#0a1a0a] font-heading font-bold text-lg rounded-xl hover:bg-[#1ec97a] transition-all shadow-[0_0_30px_rgba(35,223,140,0.3)] hover:shadow-[0_0_40px_rgba(35,223,140,0.5)]">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Get it on WhatsApp — Free
          </a>
          <p class="text-[#707070] text-sm mt-3">No app to download. Free forever.</p>
        </div>

        <!-- Chat mockup -->
        <div class="bg-[#111] border border-[#1a4d2a] rounded-2xl p-5 shadow-[0_0_30px_rgba(35,223,140,0.1)]">
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-[#1a4d2a]">
            <div class="w-8 h-8 rounded-full bg-[#23DF8C]/20 flex items-center justify-center text-[#23DF8C] text-sm font-bold">H</div>
            <span class="text-white text-sm font-semibold">Handled</span>
            <span class="text-[#23DF8C] text-xs ml-auto">online</span>
          </div>
          <div class="space-y-3">
            <!-- User message -->
            <div class="flex justify-end">
              <div class="bg-[#1a3a1a] rounded-2xl rounded-br-md px-4 py-2.5 max-w-[80%]">
                <p class="text-white text-sm">Remind me 30 min before every Brazil game and give me live scores</p>
                <p class="text-[#707070] text-[10px] text-right mt-1">09:41</p>
              </div>
            </div>
            <!-- Bot reply -->
            <div class="flex justify-start">
              <div class="bg-[#0d2a15] border border-[#1a4d2a] rounded-2xl rounded-bl-md px-4 py-2.5 max-w-[85%]">
                <p class="text-[#23DF8C] text-sm">Done! You'll get:</p>
                <p class="text-[#23DF8C] text-sm">- Reminder 30 min before kickoff</p>
                <p class="text-[#23DF8C] text-sm">- Live score alerts (goals, HT, FT)</p>
                <p class="text-[#23DF8C] text-sm mt-1">Next: Brazil vs Serbia, June 15 at 8pm</p>
                <p class="text-[#707070] text-[10px] mt-1">09:41</p>
              </div>
            </div>
            <!-- Score alert -->
            <div class="flex justify-start">
              <div class="bg-[#0d2a15] border border-[#23DF8C]/30 rounded-2xl rounded-bl-md px-4 py-2.5 max-w-[85%]">
                <p class="text-[#23DF8C] text-sm font-bold">GOAL! Brazil 1 - 0 Serbia (23')</p>
                <p class="text-[#23DF8C] text-sm">Vinicius Jr. Left foot, bottom corner.</p>
                <p class="text-[#707070] text-[10px] mt-1">20:23</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="px-6 py-20 border-t border-[#1a4d2a]/30">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-6 uppercase tracking-tight">
          Stop switching apps
        </h2>
        <p class="text-[#a0a0a0] text-lg leading-relaxed mb-8">
          You already follow the World Cup. FotMob for scores. FIFA app for schedule. Twitter for news. Google for stats.
          <span class="text-white font-semibold">4 apps. 104 matches. 39 days.</span>
        </p>
        <p class="text-[#23DF8C] text-xl font-heading font-bold">
          Or... one WhatsApp message.
        </p>
      </div>
    </section>

    <!-- What you can ask -->
    <section class="px-6 py-20 border-t border-[#1a4d2a]/30">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-4 uppercase tracking-tight">
          Just ask
        </h2>
        <p class="text-[#a0a0a0] text-center mb-12 max-w-xl mx-auto">
          Text Handled like you'd text a friend. Get instant answers.
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">⚽</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">Matches</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"Remind me before every Spain game"</p>
          </div>
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">📰</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">News</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"What happened in today's matches?"</p>
          </div>
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">🌟</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">Players</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"Show me Mbappe's stats"</p>
          </div>
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">🏟️</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">Stadiums</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"Where is the final being played?"</p>
          </div>
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">📊</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">Insights</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"Who is the top scorer so far?"</p>
          </div>
          <div class="bg-[#111] border border-[#1a4d2a] rounded-xl p-6 hover:border-[#23DF8C]/40 transition-all">
            <div class="text-2xl mb-3">📅</div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">Calendar</h3>
            <p class="text-[#23DF8C] text-sm font-mono">"Block my calendar for the semis"</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Live Scores -->
    <section class="px-6 py-20 border-t border-[#1a4d2a]/30">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-bold rounded-full bg-red-500/20 text-red-400 border border-red-500/30 uppercase tracking-wider">
            Live
          </div>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-white uppercase tracking-tight">
            Real-time scores in WhatsApp
          </h2>
          <p class="text-[#a0a0a0] mt-4 max-w-lg mx-auto">
            Goals, halftime, fulltime — delivered to your chat the moment it happens. No refreshing. No switching apps.
          </p>
        </div>

        <!-- Match card mockup -->
        <div class="max-w-sm mx-auto">
          <div class="bg-[#111] border border-[#1a4d2a] rounded-2xl p-6">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[#707070] text-xs uppercase tracking-wider">Group A</span>
              <span class="px-2 py-0.5 bg-red-500/20 text-red-400 text-xs font-bold rounded-full animate-pulse">LIVE 67'</span>
            </div>
            <div class="flex items-center justify-between mb-6">
              <div class="text-center">
                <div class="text-3xl mb-1">🇧🇷</div>
                <span class="text-white font-heading font-bold text-sm">BRA</span>
              </div>
              <div class="text-center">
                <span class="text-[#23DF8C] font-heading font-extrabold text-4xl">2 - 1</span>
              </div>
              <div class="text-center">
                <div class="text-3xl mb-1">🇷🇸</div>
                <span class="text-white font-heading font-bold text-sm">SRB</span>
              </div>
            </div>
            <div class="space-y-2 border-t border-[#1a4d2a] pt-4">
              <div class="flex items-center gap-2 text-sm">
                <span class="text-[#23DF8C]">23'</span>
                <span class="text-white">Vinicius Jr.</span>
                <span class="text-[#707070]">1-0</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <span class="text-[#23DF8C]">45'</span>
                <span class="text-white">Vlahovic</span>
                <span class="text-[#707070]">1-1</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <span class="text-[#23DF8C]">67'</span>
                <span class="text-white">Rodrygo</span>
                <span class="text-[#707070]">2-1</span>
              </div>
            </div>
          </div>
          <p class="text-center text-[#707070] text-sm mt-4">You get this in WhatsApp. Automatically.</p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="px-6 py-20 border-t border-[#1a4d2a]/30">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-16 uppercase tracking-tight">
          30 seconds. That's it.
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <div class="w-16 h-16 rounded-2xl bg-[#23DF8C]/10 border border-[#23DF8C]/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-[#23DF8C] text-2xl">1</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Open WhatsApp</h3>
            <p class="text-[#a0a0a0]">Tap the button below. Opens right in WhatsApp.</p>
          </div>
          <div>
            <div class="w-16 h-16 rounded-2xl bg-[#23DF8C]/10 border border-[#23DF8C]/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-[#23DF8C] text-2xl">2</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Tell it your teams</h3>
            <p class="text-[#a0a0a0]">"Follow Brazil, Argentina, and USA for me."</p>
          </div>
          <div>
            <div class="w-16 h-16 rounded-2xl bg-[#23DF8C]/10 border border-[#23DF8C]/20 flex items-center justify-center mx-auto mb-6">
              <span class="font-heading font-bold text-[#23DF8C] text-2xl">3</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-3">Never miss a moment</h3>
            <p class="text-[#a0a0a0]">Scores, reminders, news — all in your chat.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="px-6 py-20 border-t border-[#1a4d2a]/30">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-2 uppercase tracking-tight">
          Starts June 11.
        </h2>
        <h3 class="font-heading font-bold text-2xl md:text-3xl text-[#23DF8C] mb-8">
          Set up in 30 seconds.
        </h3>
        <a href="https://handled.sh/whatsapp" class="inline-flex items-center gap-3 px-10 py-5 bg-[#23DF8C] text-[#0a1a0a] font-heading font-bold text-xl rounded-xl hover:bg-[#1ec97a] transition-all shadow-[0_0_30px_rgba(35,223,140,0.3)]">
          <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Get it on WhatsApp — Free
        </a>
        <p class="text-[#707070] text-sm mt-4">No app to download. Free forever. Works on any phone.</p>
      </div>
    </section>

  </main>
  <Footer />

  <!-- Countdown Script -->
  <script>
    const kickoff = new Date('2026-06-11T00:00:00Z').getTime();
    function updateCountdown() {
      const now = new Date().getTime();
      const diff = kickoff - now;
      if (diff <= 0) {
        document.getElementById('days').textContent = '0';
        document.getElementById('hours').textContent = '0';
        document.getElementById('mins').textContent = '0';
        return;
      }
      document.getElementById('days').textContent = Math.floor(diff / (1000 * 60 * 60 * 24));
      document.getElementById('hours').textContent = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      document.getElementById('mins').textContent = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    }
    updateCountdown();
    setInterval(updateCountdown, 60000);
  </script>
</Base>
