  <script>
    // Dark/Light toggle
    const toggle = document.getElementById('theme-toggle');
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');
    const main = document.getElementById('main-content');
    const body = document.body;
    let isLight = false;

    // Check saved preference
    if (localStorage.getItem('wc-theme') === 'light') {
      isLight = true;
      applyTheme();
    }

    toggle.addEventListener('click', () => {
      isLight = !isLight;
      applyTheme();
      localStorage.setItem('wc-theme', isLight ? 'light' : 'dark');
    });

    function applyTheme() {
      if (isLight) {
        main.classList.add('light-mode');
        body.classList.add('light-mode');
        iconSun.classList.remove('hidden');
        iconMoon.classList.add('hidden');
      } else {
        main.classList.remove('light-mode');
        body.classList.remove('light-mode');
        iconSun.classList.add('hidden');
        iconMoon.classList.remove('hidden');
      }
    }
  </script>

  <script>
    const kickoff = new Date('2026-06-11T00:00:00Z').getTime();
    function updateCountdown() {
      const now = new Date().getTime();
      const diff = kickoff - now;
      if (diff <= 0) {
        document.getElementById('days').textContent = '0';
        document.getElementById('hours').textContent = '0';
        document.getElementById('mins').textContent = '0';
        return;
      }
      document.getElementById('days').textContent = Math.floor(diff / (1000 * 60 * 60 * 24));
      document.getElementById('hours').textContent = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      document.getElementById('mins').textContent = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    }
    updateCountdown();
    setInterval(updateCountdown, 60000);
  </script>
