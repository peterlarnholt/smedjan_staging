---
import Base from '../layouts/Base.astro';
---

<Base
  title="World Cup 2026 — Never miss a goal. Live scores in WhatsApp. | Handled"
  description="104 matches. 3 time zones. Zero excuses. Live scores, ticket alerts, match reminders, player stats — all in WhatsApp. No app needed. Free forever."
  canonical="https://handled.sh/worldcup/"
  icpSegment="soccer"
  geoTarget="global"
>
  <!-- SEO: Additional meta tags -->
  <meta slot="head" name="keywords" content="world cup 2026, world cup whatsapp, live scores whatsapp, world cup reminders, fifa 2026 schedule, world cup tickets, world cup match alerts, world cup calendar, world cup stadiums, handled" />
  <meta slot="head" name="author" content="Handled - handled.sh" />
  <meta slot="head" name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta slot="head" property="og:locale" content="en_US" />
  <meta slot="head" property="og:image:alt" content="World Cup 2026 live scores and match reminders in WhatsApp" />

  <!-- AEO: FAQ Schema for AI answer engines (Google, Perplexity, ChatGPT) -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How can I get World Cup 2026 live scores on WhatsApp?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Handled delivers real-time World Cup 2026 live scores directly to your WhatsApp. Just message Handled on WhatsApp, tell it which teams you follow, and you will receive goal alerts, halftime scores, and full-time results automatically. No app download needed. Free forever at handled.sh/worldcup."
        }
      },
      {
        "@type": "Question",
        "name": "How do I get World Cup 2026 match reminders?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Send a WhatsApp message to Handled saying something like 'Remind me 30 minutes before every Brazil game' and it will automatically send you reminders before each match. It can also block your calendar so meetings don't clash with games. Set up in 30 seconds at handled.sh/worldcup."
        }
      },
      {
        "@type": "Question",
        "name": "How can I get World Cup 2026 ticket alerts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tell Handled 'Alert me when semifinal tickets go on sale' and you will receive a WhatsApp message the moment tickets drop on FIFA.com. Tickets sell out in minutes, so getting the alert first gives you the best chance. Available free at handled.sh/worldcup."
        }
      },
      {
        "@type": "Question",
        "name": "When does the FIFA World Cup 2026 start?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The FIFA World Cup 2026 kicks off on June 11, 2026. The tournament is hosted across the USA, Mexico, and Canada with 48 teams playing 104 matches over 39 days. The final is on July 19, 2026."
        }
      },
      {
        "@type": "Question",
        "name": "What World Cup 2026 stadiums and cities are hosting matches?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "World Cup 2026 matches will be played across 16 stadiums in the USA, Mexico, and Canada, including MetLife Stadium (New York/New Jersey), AT&T Stadium (Dallas), SoFi Stadium (Los Angeles), Estadio Azteca (Mexico City), and BMO Field (Toronto). Ask Handled on WhatsApp for details about any venue."
        }
      },
      {
        "@type": "Question",
        "name": "Is Handled free for the World Cup?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Handled is completely free for World Cup 2026 features including live scores, match reminders, ticket alerts, player stats, and news. No app to download, no signup form. Just open WhatsApp and start chatting at handled.sh/worldcup."
        }
      }
    ]
  })} />

  <!-- GEO: Event schema for generative search engines -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "FIFA World Cup 2026",
    "startDate": "2026-06-11",
    "endDate": "2026-07-19",
    "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
    "location": [
      {"@type": "Place", "name": "MetLife Stadium", "address": {"@type": "PostalAddress", "addressLocality": "East Rutherford", "addressCountry": "US"}},
      {"@type": "Place", "name": "Estadio Azteca", "address": {"@type": "PostalAddress", "addressLocality": "Mexico City", "addressCountry": "MX"}},
      {"@type": "Place", "name": "BMO Field", "address": {"@type": "PostalAddress", "addressLocality": "Toronto", "addressCountry": "CA"}}
    ],
    "description": "The 2026 FIFA World Cup featuring 48 teams across the USA, Mexico, and Canada. 104 matches over 39 days. Get live scores, match reminders, and ticket alerts via WhatsApp with Handled.",
    "organizer": {"@type": "Organization", "name": "FIFA", "url": "https://www.fifa.com"},
    "offers": {
      "@type": "Offer",
      "name": "Handled World Cup WhatsApp Assistant",
      "price": "0",
      "priceCurrency": "USD",
      "url": "https://handled.sh/worldcup/",
      "description": "Free live scores, match reminders, ticket alerts, and player stats delivered via WhatsApp"
    }
  })} />

  <!-- Custom Nav (World Cup themed, replaces shared Nav) -->
  <nav class="fixed top-0 w-full z-50 backdrop-blur-md border-b" style="background:rgba(10,26,10,0.92);border-color:rgba(26,77,42,0.3);">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="https://handled.sh/" class="flex items-center gap-3">
        <img src={`${import.meta.env.BASE_URL}logo.svg`} alt="Handled" class="w-8 h-8" />
        <span class="font-heading font-bold text-xl text-white tracking-tight">handled.sh</span>
      </a>
      <a href="https://handled.sh/whatsapp" style="background:#23DF8C;color:#0a1a0a;box-shadow:0 0 20px rgba(35,223,140,0.3);" class="px-5 py-2.5 font-heading font-semibold text-sm rounded-lg hover:opacity-90 transition-all">
        Get it on WhatsApp
      </a>
    </div>
  </nav>

  <!-- Dark/Light toggle -->
  <button
    id="theme-toggle"
    class="fixed top-24 right-4 z-50 w-10 h-10 rounded-full bg-[#1a4d2a] border border-[#23DF8C]/30 flex items-center justify-center text-[#23DF8C] hover:bg-[#23DF8C]/20 transition-all"
    aria-label="Toggle light/dark mode"
  >
    <svg id="icon-sun" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg id="icon-moon" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <!-- Sub-nav: World Cup sections -->
  <div class="fixed top-[60px] left-0 right-0 z-40 bg-[#0a1a0a]/95 backdrop-blur-md border-b border-[#1a4d2a]/30 transition-colors duration-300" id="sub-nav">
    <div class="overflow-x-auto scrollbar-hide">
      <div class="flex items-center gap-1 px-4 py-2 min-w-max mx-auto justify-center">
        <a href="#scores" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Scores</a>
        <a href="#standings" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Standings</a>
        <a href="#teams" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Teams</a>
        <a href="#knockout" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Knockout</a>
        <a href="#stadiums" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Stadiums</a>
        <a href="#tickets" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Tickets</a>
        <a href="#stats" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">Stats</a>
        <a href="#news" class="px-3 py-1.5 text-[11px] md:text-xs font-heading font-semibold uppercase tracking-wider text-[#a0a0a0] hover:text-[#23DF8C] transition-colors whitespace-nowrap rounded-lg hover:bg-[#23DF8C]/10">News</a>
      </div>
    </div>
  </div>

  <style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

    /* Light mode nav + footer */
    .light-mode #sub-nav { background: rgba(245,247,245,0.95) !important; border-color: #c0d8c0 !important; }
    .light-mode #sub-nav a { color: #5a6a5a !important; }
    .light-mode #sub-nav a:hover { color: #0a8a4a !important; background: rgba(10,138,74,0.1) !important; }
  </style>

  <main class="pt-[100px] bg-[#0a1a0a] transition-colors duration-300" id="main-content">

    <!-- Hero -->
    <section class="min-h-[90vh] flex items-center px-5 py-12 md:px-6 md:py-16 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]">
        <div class="absolute top-1/2 left-0 right-0 h-px bg-[#23DF8C]"></div>
        <div class="absolute top-1/2 left-1/2 w-32 h-32 border border-[#23DF8C] rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      </div>

      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8 md:gap-12 items-center relative z-10">
        <div>
          <div class="inline-block px-4 py-1.5 mb-5 text-xs font-semibold rounded-full bg-[#23DF8C]/10 text-[#23DF8C] border border-[#23DF8C]/20 font-mono tracking-wider uppercase">
            FIFA World Cup 2026
          </div>
          <h1 class="font-heading font-extrabold text-3xl md:text-5xl lg:text-6xl text-white tracking-tight leading-[1.1] mb-2">
            NEVER MISS<br/>A GOAL.
          </h1>
          <h2 class="font-heading font-extrabold text-2xl md:text-4xl lg:text-5xl text-[#23DF8C] tracking-tight leading-tight mb-5">
            LIVE IN YOUR WHATSAPP.
          </h2>
          <p class="text-[#a0a0a0] text-base md:text-lg mb-6 leading-relaxed max-w-md">
            104 matches. 3 time zones. 39 days of pure football.
            Scores, reminders, news, tickets — one chat handles everything.
            <span class="text-white font-semibold">No app. No tab. No excuse.</span>
          </p>

          <!-- Countdown -->
          <div class="flex gap-3 mb-6" id="countdown">
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-lg px-3 py-2 text-center min-w-[60px]">
              <div class="text-[#23DF8C] font-heading font-bold text-xl md:text-2xl" id="days">--</div>
              <div class="text-[#555] text-[10px] uppercase tracking-wider">Days</div>
            </div>
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-lg px-3 py-2 text-center min-w-[60px]">
              <div class="text-[#23DF8C] font-heading font-bold text-xl md:text-2xl" id="hours">--</div>
              <div class="text-[#555] text-[10px] uppercase tracking-wider">Hours</div>
            </div>
            <div class="bg-[#141f14] border border-[#1a4d2a] rounded-lg px-3 py-2 text-center min-w-[60px]">
              <div class="text-[#23DF8C] font-heading font-bold text-xl md:text-2xl" id="mins">--</div>
              <div class="text-[#555] text-[10px] uppercase tracking-wider">Min</div>
            </div>
          </div>

          <a href="https://handled.sh/whatsapp" class="inline-flex items-center gap-3 px-7 py-3.5 bg-[#23DF8C] text-[#0a1a0a] font-heading font-bold text-base md:text-lg rounded-xl hover:bg-[#1ec97a] transition-all shadow-[0_0_30px_rgba(35,223,140,0.3)] w-full sm:w-auto justify-center">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Get it on WhatsApp
          </a>
          <p class="text-[#555] text-xs mt-2">Free forever. No app to download.</p>
        </div>

        <!-- Chat mockup -->
        <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-2xl p-4 md:p-5 shadow-[0_0_30px_rgba(35,223,140,0.08)]">
          <div class="flex items-center gap-2 mb-3 pb-2 border-b border-[#1a4d2a]/50">
            <div class="w-7 h-7 rounded-full bg-[#23DF8C]/20 flex items-center justify-center text-[#23DF8C] text-xs font-bold">H</div>
            <span class="text-white text-sm font-semibold">Handled</span>
            <span class="text-[#23DF8C] text-[10px] ml-auto">online</span>
          </div>
          <div class="space-y-2.5">
            <div class="flex justify-end">
              <div class="bg-[#1a3a1a] rounded-2xl rounded-br-md px-3 py-2 max-w-[85%]">
                <p class="text-white text-[13px]">Follow Argentina for me. Live scores, reminders, everything.</p>
                <p class="text-[#555] text-[9px] text-right mt-0.5">09:41</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-[#0d2a15] border border-[#1a4d2a]/50 rounded-2xl rounded-bl-md px-3 py-2 max-w-[88%]">
                <p class="text-[#23DF8C] text-[13px] font-medium">You're locked in. I'll send you:</p>
                <p class="text-[#23DF8C]/80 text-[13px]">- Reminders 30 min before kickoff</p>
                <p class="text-[#23DF8C]/80 text-[13px]">- Live goals, HT, FT alerts</p>
                <p class="text-[#23DF8C]/80 text-[13px]">- Post-match summary</p>
                <p class="text-[#23DF8C] text-[13px] font-medium mt-1">First up: Argentina vs Saudi Arabia, June 14</p>
                <p class="text-[#555] text-[9px] mt-0.5">09:41</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-[#0d2a15] border border-[#23DF8C]/30 rounded-2xl rounded-bl-md px-3 py-2 max-w-[88%]">
                <p class="text-white text-[13px] font-bold">GOOOOOL! Argentina 1 - 0</p>
                <p class="text-[#23DF8C] text-[13px]">Messi. Free kick. Top corner. 23'</p>
                <p class="text-[#555] text-[9px] mt-0.5">20:23</p>
              </div>
            </div>
            <div class="flex justify-end">
              <div class="bg-[#1a3a1a] rounded-2xl rounded-br-md px-3 py-2 max-w-[85%]">
                <p class="text-white text-[13px]">Alert me when semifinal tickets drop</p>
                <p class="text-[#555] text-[9px] text-right mt-0.5">20:24</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-[#0d2a15] border border-[#1a4d2a]/50 rounded-2xl rounded-bl-md px-3 py-2 max-w-[88%]">
                <p class="text-[#23DF8C] text-[13px]">Done. I'll message you the moment semifinal tickets go on sale.</p>
                <p class="text-[#555] text-[9px] mt-0.5">20:24</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="px-5 py-16 md:px-6 md:py-20 border-t border-[#1a4d2a]/20">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-heading font-bold text-2xl md:text-4xl text-white mb-5 uppercase tracking-tight leading-tight">
          YOUR WORLD CUP IS SCATTERED<br/>ACROSS 5 APPS
        </h2>
        <p class="text-[#a0a0a0] text-base md:text-lg leading-relaxed mb-6">
          FotMob for scores. FIFA for fixtures. Twitter for drama.
          Google for stats. Your calendar for... nothing, because you forgot to add the matches.
        </p>
        <p class="text-[#23DF8C] text-lg md:text-xl font-heading font-bold">
          One WhatsApp message replaces all of it.
        </p>
      </div>
    </section>

    <!-- What you can ask -->
    <section class="px-5 py-16 md:px-6 md:py-20 border-t border-[#1a4d2a]/20">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-heading font-bold text-2xl md:text-4xl text-white text-center mb-3 uppercase tracking-tight">
          JUST TEXT IT
        </h2>
        <p class="text-[#a0a0a0] text-center mb-10 max-w-md mx-auto text-sm md:text-base">
          Ask anything about the World Cup. Like texting a friend who knows everything.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Live scores</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Give me live updates for every match today"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Reminders</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Remind me 30 min before every Spain game"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Tickets</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Alert me when quarterfinal tickets drop"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">News</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"What happened in todays matches?"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Players</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"How many goals has Mbappe scored?"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Stadiums</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Where is the final? How do I get there?"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Standings</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Show me Group B table after today"</p>
          </div>
          <div class="bg-[#0d0d0d] border border-[#1a4d2a] rounded-xl p-4 md:p-5 hover:border-[#23DF8C]/40 transition-all">
            <h3 class="font-heading font-bold text-white text-sm md:text-base mb-1.5 uppercase tracking-wide">Calendar</h3>
            <p class="text-[#23DF8C] text-xs md:text-sm font-mono leading-relaxed">"Block my calendar for every knockout game"</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Live Scores -->
    <section id="scores" class="px-5 py-16 md:px-6 md:py-20 border-t border-[#1a4d2a]/20 scroll-mt-28">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <div class="inline-block px-3 py-1 mb-3 text-[10px] font-bold rounded-full bg-red-500/20 text-red-400 border border-red-500/30 uppercase tracking-widest">
            Live
